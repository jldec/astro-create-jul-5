{
  "name": "astro-create-jul-5",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro build && astro preview",
    "astro": "astro",
    "check": "astro check && prettier --check .",
