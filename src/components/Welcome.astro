<div class="flex min-h-screen flex-col items-center justify-center gap-6 text-center">
	<div class="text-5xl font-bold text-orange-500">astro-create-jul-5</div>
	<div class="flex flex-col items-center gap-3">
		<button
			id="time-button"
			type="button"
			class="cursor-pointer rounded-lg bg-orange-500 px-4 py-2 text-lg font-semibold text-white transition-transform duration-100 hover:bg-orange-600 active:translate-y-0.5"
		>
			time
		</button>
		<p id="time-result" class="min-h-[1.5rem] whitespace-pre-line font-mono text-base text-gray-700"></p>
	</div>
</div>

<script>
	const button = document.getElementById('time-button')
	const result = document.getElementById('time-result')

	button?.addEventListener('click', async () => {
		try {
			const start = performance.now()
			const response = await fetch('/time')
			const rtt = Math.round(performance.now() - start)

			if (!response.ok) {
				result.textContent = `Error: ${response.status}`
				return
			}

			result.textContent = `${await response.text()}\n${rtt} ms`
		} catch (error) {
			result.textContent = error instanceof Error ? error.message : 'Request failed'
		}
	})
</script>