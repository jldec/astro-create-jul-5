{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "compatibility_date": "2026-07-05",
  "compatibility_flags": ["global_fetch_strictly_public"],
  "name": "astro-create-jul-5",
  "main": "./src/worker.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
